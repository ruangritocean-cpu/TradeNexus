# Exclude local package virtual environment
.venv/
venv/
env/

# Exclude git repository data
.git/
.github/

# Exclude local databases and data caches
data/*.sqlite
data/*.db
data/cache/

# Exclude test caches and coverage reports
.pytest_cache/
.coverage
htmlcov/

# Exclude temporary scratch scripts and logs
scratch/
*.log

# Exclude Python build/compile outputs
__pycache__/
*.pyc
*.pyo
*.pyd

# Exclude OS generated files
.DS_Store
Thumbs.db
